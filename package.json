{
	"name": "@linxinhong/pi-claw",
	"version": "1.0.0",
	"description": "Multi-platform bot gateway with plugin architecture",
	"type": "module",
	"main": "dist/main.js",
	"types": "dist/main.d.ts",
	"bin": {
		"pi-claw": "./dist/cli.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc",
		"start": "node dist/main.js",
		"dev": "tsx src/main.ts",
		"typecheck": "tsc --noEmit",
		"init": "bash scripts/init-workspace.sh",
		"init:ts": "tsx scripts/init-workspace.ts",
		"lock": "bash scripts/lock-config.sh lock",
		"unlock": "bash scripts/lock-config.sh unlock",
		"config:status": "bash scripts/lock-config.sh status",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:unit": "vitest run tests/unit",
		"test:watch": "vitest watch"
	},
	"dependencies": {
		"@larksuiteoapi/node-sdk": "^1.29.0",
		"@mariozechner/pi-agent-core": "^0.55.3",
		"@mariozechner/pi-ai": "^0.55.3",
		"@mariozechner/pi-coding-agent": "^0.55.3",
		"@sinclair/typebox": "^0.34.48",
		"commander": "^12.0.0",
		"croner": "^8.0.0",
		"express": "^4.18.2",
		"openai": "^4.0.0"
	},
	"devDependencies": {
		"@types/express": "^4.17.21",
		"@types/node": "^20.0.0",
		"@vitest/coverage-v8": "^2.0.0",
		"tsx": "^4.0.0",
		"typescript": "^5.0.0",
		"vitest": "^2.0.0"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
